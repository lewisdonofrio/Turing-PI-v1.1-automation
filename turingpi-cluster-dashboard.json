  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["turingpi", "armv7", "cluster"],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "label": "Node",
        "datasource": "Prometheus",
        "query": "label_values(node_boot_time_seconds, instance)",
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "sort": 1,
        "current": {
          "text": "kubenode2:9100",
          "value": "kubenode2"
        },
        "regex": "/^(.*):9100$/",
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
